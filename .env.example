# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Anthropic API base URL (e.g. for a proxy or local model server)
ANTHROPIC_BASE_URL=

# Model passed to client.messages.create (e.g. claude-opus-4-7, or an Ollama model via ANTHROPIC_BASE_URL)
MODEL_NAME=
